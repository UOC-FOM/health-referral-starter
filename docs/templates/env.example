# Health Referral System - Environment Configuration
# Copy this to .env: cp docs/templates/env.example .env
# Fill in YOUR values from your own Supabase project dashboard.

# Database (your own Supabase project)
# From: Supabase Dashboard → Connect button → Session pooler tab
SUPABASE_DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_POSTGRES_PASSWORD
SUPABASE_DB_SCHEMA=public

# Supabase API (React frontend — Module 05+)
# From: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_API_BASE_URL=http://localhost:8000/api

# JWT (Module 04+)
JWT_SECRET=REPLACE_WITH_YOUR_32_CHAR_JWT_SECRET
JWT_EXPIRY=3600
